// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  senhaHash String   @map("senha_hash")
  nome      String?
  criadoEm  DateTime @default(now()) @map("criado_em")

  @@map("usuarios")
}

model Noticia {
  id           Int      @id @default(autoincrement())
  titulo       String   @db.VarChar(255)
  resumo       String?  @db.Text
  conteudo     String?  @db.Text
  categoria    String?  @db.VarChar(100)
  corCategoria String?  @db.VarChar(50) @map("cor_categoria")
  urlImagem    String?  @db.VarChar(500) @map("url_imagem")
  criadoEm     DateTime @default(now()) @map("criado_em")

  @@map("noticias")
}

model Atividade {
  id           Int      @id @default(autoincrement())
  titulo       String   @db.VarChar(255)
  descricao    String?  @db.Text
  insignias    String[]
  valorAlvo    String?  @db.VarChar(100) @map("valor_alvo")
  rotuloAlvo   String?  @db.VarChar(100) @map("rotulo_alvo")
  objetivo     String?  @db.VarChar(255)
  componenteId Int?     @map("componente_id")
  tipoAcao     String?  @db.VarChar(100) @map("tipo_acao")
  demandante   String?  @db.VarChar(100)
  estados      String[]
  hectares              String?  @db.VarChar(100)
  valorImpacto          String?  @db.VarChar(100) @map("valor_impacto")
  rotuloImpacto         String?  @db.VarChar(100) @map("rotulo_impacto")
  metrica1Valor         String?  @db.VarChar(100) @map("metrica1_valor")
  metrica1Rotulo        String?  @db.VarChar(100) @map("metrica1_rotulo")
  delineamentoDescricao String?  @db.Text @map("delineamento_descricao")
  parceiros             String[]
  data                  String?  @db.VarChar(100)
  status                String   @default("publicado") @db.VarChar(20)
  criadoEm              DateTime @default(now()) @map("criado_em")

  imagens      AtividadeImagem[]
  pontos       AtividadePonto[]

  @@map("atividades")
}

model AtividadeImagem {
  id          Int       @id @default(autoincrement())
  atividadeId Int       @map("atividade_id")
  url         String    @db.VarChar(500)
  ordem       Int       @default(0)
  legenda     String?   @db.VarChar(255)
  atividade   Atividade @relation(fields: [atividadeId], references: [id], onDelete: Cascade)

  @@map("atividade_imagens")
}

model AtividadePonto {
  id          Int       @id @default(autoincrement())
  atividadeId Int       @map("atividade_id")
  lat         Float
  lng         Float
  rotulo      String?   @db.VarChar(100)
  ordem       Int       @default(0)
  atividade   Atividade @relation(fields: [atividadeId], references: [id], onDelete: Cascade)

  @@map("atividade_pontos")
}

model Depoimento {
  id        Int      @id @default(autoincrement())
  citacao   String?  @db.Text
  nome      String?  @db.VarChar(100)
  cargo     String?  @db.VarChar(100)
  urlAvatar String?  @db.VarChar(500) @map("url_avatar")
  criadoEm  DateTime @default(now()) @map("criado_em")

  @@map("depoimentos")
}

model DocumentoRepositorio {
  id             Int      @id @default(autoincrement())
  titulo         String   @db.VarChar(255)
  descricao      String?  @db.Text
  tipoIcone      String?  @db.VarChar(50) @map("tipo_icone")
  tamanhoArquivo String?  @db.VarChar(50) @map("tamanho_arquivo")
  tipoDocumento  String?  @db.VarChar(50) @map("tipo_documento")
  urlArquivo     String?  @db.VarChar(500) @map("url_arquivo")
  criadoEm       DateTime @default(now()) @map("criado_em")

  @@map("documentos_repositorio")
}

model EstatisticaDashboard {
  id           Int      @id @default(autoincrement())
  nomeChave    String   @unique @db.VarChar(100) @map("nome_chave")
  valor        String?  @db.VarChar(50)
  unidade      String?  @db.VarChar(20)
  classeCor    String?  @db.VarChar(50) @map("classe_cor")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  @@map("estatisticas_dashboard")
}

model PerguntaFrequente {
  id       Int     @id @default(autoincrement())
  pergunta String? @db.Text
  resposta String? @db.Text
  ordem    Int?

  @@map("perguntas_frequentes")
}
