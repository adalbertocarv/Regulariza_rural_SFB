// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("users")
}

model News {
  id            Int      @id @default(autoincrement())
  title         String   @db.VarChar(255)
  excerpt       String?  @db.Text
  content       String?  @db.Text
  category      String?  @db.VarChar(100)
  categoryColor String?  @db.VarChar(50) @map("category_color")
  imageUrl      String?  @db.VarChar(500) @map("image_url")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("news")
}

model Activity {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  description String?  @db.Text
  badges      String[]
  targetValue String?  @db.VarChar(100) @map("target_value")
  targetLabel String?  @db.VarChar(100) @map("target_label")
  objective   String?  @db.VarChar(255)
  imageUrl    String?  @db.VarChar(500) @map("image_url")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("activities")
}

model Testimonial {
  id        Int      @id @default(autoincrement())
  quote     String?  @db.Text
  name      String?  @db.VarChar(100)
  role      String?  @db.VarChar(100)
  avatarUrl String?  @db.VarChar(500) @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("testimonials")
}

model RepositoryDocument {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  description String?  @db.Text
  iconType    String?  @db.VarChar(50) @map("icon_type")
  fileSize    String?  @db.VarChar(50) @map("file_size")
  docType     String?  @db.VarChar(50) @map("doc_type")
  fileUrl     String?  @db.VarChar(500) @map("file_url")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("repository_documents")
}

model DashboardStat {
  id         Int      @id @default(autoincrement())
  keyName    String   @unique @db.VarChar(100) @map("key_name")
  value      String?  @db.VarChar(50)
  unit       String?  @db.VarChar(20)
  colorClass String?  @db.VarChar(50) @map("color_class")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("dashboard_stats")
}

model Faq {
  id       Int     @id @default(autoincrement())
  question String? @db.Text
  answer   String? @db.Text
  orderNum Int?    @map("order_num")

  @@map("faqs")
}
