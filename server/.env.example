# Variáveis de Ambiente - Regulariza Rural Server
# Copie este arquivo para .env e preencha os valores

# Conexão com PostgreSQL
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:sua_senha@localhost:5432/regulariza_rural"

# Chave secreta para geração de tokens JWT (use uma string longa e aleatória)
JWT_SECRET="troque_por_uma_chave_secreta_muito_longa_e_aleatoria"

# Expiração do token JWT (ex: 7d, 24h, 30m)
JWT_EXPIRES_IN="7d"

# Porta do servidor
PORT=3001

# URL base para servir os uploads (deve apontar para onde o server roda)
UPLOAD_BASE_URL="http://localhost:3001"

# Ambiente (development | production)
NODE_ENV="development"
